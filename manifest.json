{
  "manifest_version": 3,
  "name": "SideThreadGPT",
  "version": "0.1.0",
  "description": "ChatGPT Branching in a Sidebar",
  "action": {
    "default_title": "Open SideThreadGPT"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}


