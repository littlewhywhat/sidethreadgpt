{
  "manifest_version": 3,
  "name": "ChatGPT Side Panel Hello World",
  "version": "0.1.0",
  "description": "Basic extension that opens a side panel with ChatGPT iframe.",
  "action": {
    "default_title": "Open Side Panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}


